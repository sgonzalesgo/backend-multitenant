# esta es la url de la api externa para la creacion de una persona
DINARDAP_BASE_URL=https://geoapi.esmeraldas.gob.ec/new/dinardap
DINARDAP_CODIGO_PAQUETE=3789


AUTH_GUARD=api

AUTH_ACCESS_COOKIE=access_token
AUTH_REFRESH_COOKIE=refresh_token
AUTH_TENANT_COOKIE=tenant_id

AUTH_ACCESS_TOKEN_MINUTES=300
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_IMPERSONATION_TOKEN_MINUTES=300
AUTH_BACKUP_TOKEN_MINUTES=300

# Sessions (OK en database, aunque para más performance luego puedes migrarlas a redis)
SESSION_DRIVER=database
SESSION_LIFETIME=300
SESSION_EXPIRE_ON_CLOSE=false

SESSION_PATH=/
SESSION_DOMAIN=.eduolivo.test
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
