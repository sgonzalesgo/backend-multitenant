APP_NAME="Eduolivo"
APP_ENV=local
APP_KEY=base64:JWp0mAGFdzSDPHR3FIxfCcmdht+JuBRtZKFXzRa+BpU=
APP_DEBUG=true
APP_URL=https://api.eduolivo.test

# la url del frontend que se usara
FRONTEND_URL=https://app.eduolivo.test

APP_TIMEZONE=UTC

#Definir cada cuantos segundo se hace el ping para verificar que un usuario esta online
PRESENCE_TTL_SECONDS=300


APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=backend-multitenant
DB_USERNAME=postgres
DB_PASSWORD=salvigun

# Definir un uuid para un tenant fijo que usaremos global
LANDLORD_TEAM_ID=00000000-0000-0000-0000-000000000001

# Broadcasting (Reverb)
BROADCAST_CONNECTION=reverb

FILESYSTEM_DISK=local

# Queue (EFICIENTE: redis) -> requiere correr: php artisan queue:work
# Para el envio de correo debe ser sync
QUEUE_CONNECTION=redis

# Cache (EFICIENTE: redis)/ sync que era como lo tenia antes
CACHE_STORE=redis
MEMCACHED_HOST=127.0.0.1

# Redis
# Si tienes la extensión php redis instalada, phpredis es más rápido que predis.
# Si realmente estás usando predis/predis, cambia a: REDIS_CLIENT=predis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
REDIS_DB=1
REDIS_PREFIX=
CACHE_PREFIX=school_chat_

# Mailtrap
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=e89c0f90f6bd60
MAIL_PASSWORD=9c00903b8cd44a
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=admin@eduolivo.com
MAIL_FROM_NAME="Mi App"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
